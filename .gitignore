# Ignore local wow-tools build outputs
/wow-tools/

# Ignore custom and auto-generated configs
/configs/*.conf
/configs/modules/*.conf
/configs/admin_password.txt
/configs/modules.json

# Ignore WoW client data files (dbc, maps, vmaps, mmaps)
/configs/data/*
!/configs/data/.gitkeep

# Ignore custom lua scripts
/lua_scripts/*
!/lua_scripts/.gitkeep

