[mysqld]
port=3310
bind-address=0.0.0.0
datadir=/opt/acore/data
skip-networking=0
skip-bind-address=0

# --- PERFORMANCE OPTIMIZATIONS FOR 4000+ PLAYERBOTS ---
# Cache 1.5 GB of RAM — fits DB tables in memory, avoids disk I/O on 8 GB host
innodb_buffer_pool_size = 1536M

# Flush once/sec instead of on every commit — drastically reduces write latency
innodb_flush_log_at_trx_commit = 2

# Larger log files mean fewer checkpoint flushes
innodb_log_file_size = 256M
innodb_log_buffer_size = 64M

# Skip OS page cache double-buffering
innodb_flush_method = O_DIRECT

# Parallel I/O threads for reads and writes
innodb_write_io_threads = 4
innodb_read_io_threads = 4

# Connection pool
max_connections = 200
thread_cache_size = 8
